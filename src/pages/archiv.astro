---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const ausgaben = (await getCollection('ausgaben')).sort(
  (a, b) => b.data.datum.getTime() - a.data.datum.getTime(),
);
---
<Base title="FuturX · Weiterbildungen & Impulse – Archiv" markeTarget="/" markeText="Aktuell">
  <Fragment slot="hero">
    <span class="hero__eyebrow">Übersicht</span>
    <h1>Archiv</h1>
    <p class="hero__teaser">Alle Ausgaben von «Weiterbildungen & Impulse». Abgelaufene Kurse bleiben erhalten und sind markiert.</p>
  </Fragment>

  <ul class="archiv">
    {ausgaben.map((a) => (
      <li>
        <a href={`${base}/ausgabe/${a.id}`}>
          <span class="archiv__titel">{a.data.titel}</span>
          <span class="archiv__datum">{a.data.monatLabel}</span>
        </a>
      </li>
    ))}
  </ul>
</Base>
