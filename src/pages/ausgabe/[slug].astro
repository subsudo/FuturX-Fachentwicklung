---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import AusgabeInhalt from '../../components/AusgabeInhalt.astro';

export async function getStaticPaths() {
  const ausgaben = await getCollection('ausgaben');
  return ausgaben.map((a) => ({ params: { slug: a.id }, props: { ausgabe: a } }));
}

const { ausgabe } = Astro.props;
const d = ausgabe.data;
---
<Base title={`FuturX · Weiterbildungen & Impulse – ${d.monatLabel}`} markeTarget="/archiv" markeText="Archiv">
  <Fragment slot="hero">
    <span class="hero__eyebrow">Ausgabe {d.monatLabel}</span>
    <h1 set:html="Weiter&shy;bildungen &amp; Impulse" />
    <p class="hero__teaser">{d.einleitung}</p>
  </Fragment>

  <AusgabeInhalt ausgabeSlug={ausgabe.id} />
</Base>
