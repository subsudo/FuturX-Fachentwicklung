---
import { render } from 'astro:content';
export interface Props { ressource: any; }
const { ressource } = Astro.props;
const { Content } = await render(ressource);
const d = ressource.data;
const typLabel: Record<string, string> = {
  studie: 'Studie',
  bericht: 'Bericht',
  artikel: 'Artikel',
  podcast: 'Podcast',
  video: 'Video',
  webinar: 'Webinar',
  toolkit: 'Toolkit',
  fachstelle: 'Fachstelle',
};
const bereichLabel: Record<string, string> = {
  berufsintegration: 'Berufsintegration',
  bildung: 'Bildung',
  beratung: 'Beratung',
  uebergreifend: 'Übergreifend',
};
---
<details class="eintrag">
  <summary>
    <div class="eintrag__main">
      <div class="eintrag__titel">{d.titel}</div>
      <div class="eintrag__chips">
        <span class="chip--klein chip--gruen">{typLabel[d.typ] ?? d.typ}</span>
        {d.kostenlos && <span class="chip--klein">kostenlos</span>}
      </div>
      <div class="eintrag__meta">{d.quelle} · {bereichLabel[d.bereich]}{d.datumLabel ? ` · ${d.datumLabel}` : ''}</div>
    </div>
    <span data-chev class="chev">▾</span>
  </summary>
  <div class="eintrag__body">
    <p class="ressource__warum">{d.warum}</p>
    <Content />
    <a href={d.url} target="_blank" rel="noopener" class="link-beere">Zur Quelle →</a>
  </div>
</details>
